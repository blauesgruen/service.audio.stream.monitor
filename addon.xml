<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.monitor.radio_de_light" name="Radio.de Light Monitor Service" provider-name="blauesgruen" version="1.0.0">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests" />
  </requires>
  <extension point="xbmc.service" library="service.py" start="login" />
  <extension point="xbmc.addon.metadata">
    <summary lang="de_DE">Monitor Service für Radio.de Light</summary>
    <summary lang="en_GB">Monitor Service for Radio.de Light</summary>
    <description lang="de_DE">Überwacht Radio-Streams und zeigt aktuelle Song-Informationen (Titel, Interpret, etc.) korrekt an. Löscht Properties automatisch beim Stoppen oder Addon-Wechsel.</description>
    <description lang="en_GB">Monitors radio streams and displays current song information (title, artist, etc.) correctly. Clears properties automatically when stopping or switching addons.</description>
    <language>de</language>
    <platform>all</platform>
    <license>MIT</license>
    <assets>
        <icon>icon.png</icon>
        <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon>
